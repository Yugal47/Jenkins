pipeline {
    agent any
    tools {
        jdk "jdk21"
        maven "maven3"
        nodejs "node"
    }
    stages {
        stage('Git Checkout') {
            steps {
                git branch: 'main', credentialsId: 'github-ssh', url: 'git@gitlab.com:devops-projectss/shareapp.git'  //this should be changed
            }
        }
        stage('compiling') {
            steps {
                dir("backend/"){
                    sh "mvn compile"
                }
            }
        }
        stage('mvn test') {
            steps {
                dir("backend/"){
                    sh "mvn test"
                }
            }
        }
        stage('packaging') {
            steps {
                dir("backend/"){
                    sh "mvn package -DSkipTests"
                }
            }
        }
        stage('compiling frontend') {
            steps {
                dir("frontend/"){
                    sh "npm install"
                }
            }
        }
        stage('docker login') {
            steps {
                withCredentials([gitUsernamePassword(credentialsId: 'dockerhub-cred', gitToolName: 'Default Git')]) {
                    echo "docker logged in"
                }
            }
        }
        stage('docker building app1') {
            steps {
                dir("backend/"){
                    sh """
                        docker build -t yugal47/shareappbackend .
                    """
                }
            }
        }
        stage('docker building app2') {
            steps {
                dir("frontend/"){
                    sh """
                        docker build -t yugal47/shareappfrontend .
                    """
                }
            }
        }
        stage('starting app') {
            steps {
                sh """
                    docker compose up -d --build
                """
            }
        }
	stage('starting app') {
            steps {
                dir("share-app/helm"){
		withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {     //this should be changed
			sh """
                            helm upgrade --install share-app .
			"""
		}
            }
	}
    }
}

